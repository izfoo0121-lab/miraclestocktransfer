# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# From @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram group chat ID (negative number, e.g. -1001234567890)
# Send a message in the group then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat": {"id": -100xxxxxxx}
GROUP_ID=-1001234567890

# Telegram usernames of people who can approve (comma separated, no @ symbol)
# Example: GT138888,brian_jw,kelvin555
APPROVERS=GT138888
